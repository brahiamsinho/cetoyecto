# CUP-FICCT deployment configuration
# Copy this file to the repository root as `.env` and fill in the secrets.

# Domain / DNS (must be defined before the URLs that reference ${DOMAIN})
DOMAIN=cupficct.duckdns.org
DUCKDNS_TOKEN=
DUCKDNS_DOMAIN=cupficct.duckdns.org

# Application
APP_NAME=CUP-FICCT
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000/
APP_FRONTEND_URL=http://localhost:5173/
# SSL
CERTBOT_EMAIL=

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cup_ficct
DB_USERNAME=postgres
DB_PASSWORD=secret

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="CUP FICCT"

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Laravel session / Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173
SESSION_DOMAIN=localhost

# Frontend dev proxy
VITE_API_TARGET=http://backend:8000

# External services
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
